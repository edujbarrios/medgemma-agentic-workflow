"""Development environment configuration."""

# Add this to your .env file for local development

# Hugging Face Configuration
HUGGINGFACE_TOKEN=your_hf_token_here  # For gated models
MEDGEMMA_MODEL_ID=google/medgemma-7b-it

# Model Configuration
MEDGEMMA_DEVICE=auto  # "cuda" for GPU, "cpu" for CPU, "auto" for automatic
MEDGEMMA_TORCH_DTYPE=float16  # "float16", "float32", "bfloat16"

# Application Settings
LOG_LEVEL=DEBUG
DEBUG=true

# Paths
TEMPLATE_DIR=./templates
CONFIG_DIR=./configs
PROMPTS_DIR=./prompts

# Development
PYTHONUNBUFFERED=1
